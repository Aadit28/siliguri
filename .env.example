# Copy to .env and fill in. Get values from Supabase dashboard -> Settings -> API.
EXPO_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-public-key
EXPO_PUBLIC_API_BASE_URL=http://localhost:8788

# Server-side only. Used by scripts/seed.mjs and Vercel API routes. Never expose in the app.
SUPABASE_SERVICE_ROLE_KEY=your-service-role-secret

# Optional server-side AI planner for /api/assistant/plan. Leave blank to use the local planner.
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=gpt-4.1-mini
